            "url": {
              "raw": "{{baseUrl}}/rest/companies/{{id}}",
              "host": ["{{baseUrl}}"],
              "path": ["rest", "companies", "{{id}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Opportunities",
      "item": [
        {
          "name": "List opportunities",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/rest/opportunities",
              "host": ["{{baseUrl}}"],
              "path": ["rest", "opportunities"]
            }
          }
        },
        {
          "name": "Create an opportunity",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Acme - Platform Deal\",\n  \"stage\": \"PROPOSAL\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
